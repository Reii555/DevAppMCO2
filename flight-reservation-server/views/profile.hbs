<div class="container my-4">
    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-5">
            <div class="profile-card p-4">
                <!-- Personal Information -->
                <div class="mb-4">
                    <div class="section-title">Personal Information</div>

                    <!-- Avatar -->
                    <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                        <div class="avatar-wrapper" id="avatarPreview">
                            {{#if user.profilePicture}}
                                {{#if (eq user.profilePicture "placeholder")}}
                                    <i class="fas fa-user avatar-placeholder"></i>
                                {{else}}
                                    <img src="{{user.profilePicture}}" alt="Profile Picture">
                                {{/if}}
                            {{else}}
                                <i class="fas fa-user avatar-placeholder"></i>
                            {{/if}}
                        </div>
                        <div>
                            <button class="btn-upload" id="uploadBtn">
                                <i class="fas fa-camera me-1"></i> Upload photo
                            </button>
                            <input type="file" id="avatarUpload" accept="image/jpeg,image/png,image/jpg" style="display: none;">
                            <div class="text-muted small mt-1">PNG, JPG up to 2MB</div>
                        </div>
                    </div>

                    <!-- Profile Info Display -->
                    <div class="profile-info">
                        <div class="info-row">
                            <label>Full Name</label>
                            <p>{{user.full_name}}</p>
                        </div>
                        <div class="info-row">
                            <label>Email</label>
                            <p>{{user.email}}</p>
                        </div>
                        <div class="info-row">
                            <label>Contact Number</label>
                            <p>{{user.contact_num}}</p>
                        </div>
                        <div class="info-row">
                            <label>Passport Number</label>
                            <p>{{user.passport_num}}</p>
                        </div>
                        <div class="info-row">
                            <label>Nationality</label>
                            <p>{{user.nationality}}</p>
                        </div>
                        <div class="info-row">
                            <label>Date of Birth</label>
                            <p>{{formatDate user.birth_date}}</p>
                        </div>
                        <div class="info-row">
                            <label>Gender</label>
                            <p>{{user.gender}}</p>
                        </div>
                        <div class="info-row">
                            <label>Passenger Type</label>
                            <p>{{user.type}}</p>
                        </div>
                        <div class="info-row">
                            <label>Emergency Contact</label>
                            <p>{{user.emergency_contact}}</p>
                        </div>
                        <div class="info-row">
                            <label>Member Since</label>
                            <p>{{formatDate user.createdAt}}</p>
                        </div>
                    </div>

                    <div class="mt-3 d-flex justify-content-end">
                        <a href="/profile/edit" class="btn-save">
                            <i class="fas fa-edit me-1"></i> Edit Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-7">
            <!-- Saved Passengers -->
            <div class="profile-card p-4 mb-4">
                <div class="section-title">Saved Passengers</div>
                
                <!-- Add Passenger Form -->
                <div class="passenger-form mb-3 p-3">
                    <h6 class="mb-2">Add New Passenger</h6>
                    <div class="row g-2">
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="passengerFirstName" placeholder="First Name">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="passengerLastName" placeholder="Last Name">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="passengerPassport" placeholder="Passport Number">
                        </div>
                        <div class="col-6">
                            <input type="date" class="form-control form-control-sm" id="passengerDob">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="passengerNationality" placeholder="Nationality">
                        </div>
                        <div class="col-6">
                            <select class="form-select form-select-sm" id="passengerGender">
                                <option value="">Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select class="form-select form-select-sm" id="passengerType">
                                <option value="Adult">Adult</option>
                                <option value="Child">Child</option>
                                <option value="Infant">Infant</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-primary btn-sm w-100" id="addPassengerBtn">
                                <i class="fas fa-plus me-1"></i> Add Passenger
                            </button>
                        </div>
                    </div>
                </div>

                <div id="savedPassengersList">
                    {{#if user.savedPassengers.length}}
                        {{#each user.savedPassengers}}
                            <div class="passenger-item">
                                <div class="passenger-info">
                                    <span>{{this.firstName}} {{this.lastName}}</span>
                                    <span class="passenger-badge">{{this.type}}</span>
                                </div>
                                <button class="btn-remove remove-passenger" data-index="{{@index}}">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        {{/each}}
                    {{else}}
                        <p class="text-muted text-center py-2">No saved passengers yet.</p>
                    {{/if}}
                </div>
            </div>

            <!-- Travel History -->
            <div class="profile-card p-4 mb-4">
                <div class="section-title">Travel History</div>
                {{#if reservations.length}}
                    {{#each reservations}}
                        <div class="history-item">
                            <div class="d-flex justify-content-between align-items-center flex-wrap">
                                <div>
                                    <strong>{{this.flightId.flight_number}}</strong>
                                    <span class="ms-2">{{this.flightId.origin}} → {{this.flightId.destination}}</span>
                                </div>
                                <span class="status-badge status-{{this.status}}">{{this.status}}</span>
                            </div>
                            <div class="small text-muted mt-1">
                                <i class="fas fa-calendar-alt me-1"></i>
                                {{formatDate this.flightId.departureTime}}
                                <span class="mx-2">|</span>
                                Seat {{this.seatNumber}}
                            </div>
                        </div>
                    {{/each}}
                    <div class="text-center mt-3">
                        <a href="/reservations" class="btn btn-outline-primary btn-sm">
                            View All Reservations
                        </a>
                    </div>
                {{else}}
                    <p class="text-muted text-center py-2">No reservations yet. <a href="/search">Book a flight now!</a></p>
                {{/if}}
            </div>

            <!-- Payment Methods -->
            <div class="profile-card p-4 mb-4">
                <div class="section-title">Payment Methods</div>
                
                <!-- Add Payment Form -->
                <div class="payment-form mb-3 p-3">
                    <h6 class="mb-2">Add Payment Method</h6>
                    <div class="row g-2">
                        <div class="col-6">
                            <select class="form-select form-select-sm" id="paymentCardType">
                                <option value="">Card Type</option>
                                <option value="VISA">VISA</option>
                                <option value="Mastercard">Mastercard</option>
                                <option value="Maya">Maya</option>
                                <option value="GoTyme">GoTyme</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="paymentCardNumber" placeholder="Card Number (last 4 digits)">
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" id="paymentCardholder" placeholder="Cardholder Name">
                        </div>
                        <div class="col-3">
                            <input type="text" class="form-control form-control-sm" id="paymentExpiryMonth" placeholder="MM">
                        </div>
                        <div class="col-3">
                            <input type="text" class="form-control form-control-sm" id="paymentExpiryYear" placeholder="YY">
                        </div>
                        <div class="col-6">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="paymentDefault">
                                <label class="form-check-label small" for="paymentDefault">
                                    Set as default
                                </label>
                            </div>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-primary btn-sm w-100" id="addPaymentBtn">
                                <i class="fas fa-plus me-1"></i> Add Payment
                            </button>
                        </div>
                    </div>
                </div>

                <div id="paymentMethodsList">
                    {{#if user.paymentMethods.length}}
                        {{#each user.paymentMethods}}
                            <div class="payment-card {{#if this.isDefault}}active{{/if}}" data-index="{{@index}}">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fab fa-cc-{{this.cardType}} fa-2x me-2"></i>
                                        <strong>{{this.cardType}}</strong>
                                        <span class="ms-2">{{this.cardNumber}}</span>
                                        <span class="text-muted ms-2">Exp {{this.expiryMonth}}/{{this.expiryYear}}</span>
                                    </div>
                                    <div>
                                        {{#if this.isDefault}}
                                            <span class="badge bg-success">Default</span>
                                        {{else}}
                                            <button class="btn-set-default set-default-payment" data-index="{{@index}}">
                                                Set Default
                                            </button>
                                        {{/if}}
                                        <button class="btn-remove remove-payment ms-2" data-index="{{@index}}">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        {{/each}}
                    {{else}}
                        <p class="text-muted text-center py-2">No payment methods saved.</p>
                    {{/if}}
                </div>
            </div>

            <!-- Notification Preferences -->
            <div class="profile-card p-4 mb-4">
                <div class="section-title">Notification Preferences</div>
                <div class="notifications-box p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Promotional offers and deals</span>
                        <label class="toggle-switch">
                            <input type="checkbox" class="notif-toggle" data-key="promotionalOffers" 
                                {{#if user.notificationPreferences.promotionalOffers}}checked{{/if}}>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Flight status and delay alerts</span>
                        <label class="toggle-switch">
                            <input type="checkbox" class="notif-toggle" data-key="flightStatusAlerts" 
                                {{#if user.notificationPreferences.flightStatusAlerts}}checked{{/if}}>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Loyalty program updates</span>
                        <label class="toggle-switch">
                            <input type="checkbox" class="notif-toggle" data-key="loyaltyUpdates" 
                                {{#if user.notificationPreferences.loyaltyUpdates}}checked{{/if}}>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span>SMS alerts</span>
                        <label class="toggle-switch">
                            <input type="checkbox" class="notif-toggle" data-key="smsAlerts" 
                                {{#if user.notificationPreferences.smsAlerts}}checked{{/if}}>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="profile-card p-4">
                <div class="section-title">Quick Actions</div>
                <div class="row g-3">
                    <div class="col-6">
                        <a href="/search" class="btn btn-primary w-100">
                            <i class="fas fa-search me-2"></i>Search Flights
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/reservations" class="btn btn-outline-primary w-100">
                            <i class="fas fa-ticket-alt me-2"></i>My Reservations
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom JS -->
<script src="/js/profile.js"></script>