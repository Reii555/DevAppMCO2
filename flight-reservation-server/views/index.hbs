<!-- First Container -->
<div class="container-fluid my-5" id="firstContainer">
    <div class="row align-items-center">
        <div class="col-lg-5 col-md-6" id="firstContainerTxt">
            <div class="lead-text">
                <h2 class="mb-2">Connecting Journeys,</h2>
                <h2 class="mb-2">Creating Memories</h2>
            </div>

            <div class="sublead-text"> 
                <h4 class="mb-2">Welcome to Animo Skies airline, where comfort, reliability, and convenience come together.</h4>
            </div>
            
            <div class="btn-container mt-3" id="firstContainerBtn">
                <a href="#searchFlightContainer" class="btn btn-primary btn-lg" id="pressScrollSearch">Search Flights</a>
            </div>
        </div>

        <div class="col-lg-7 col-md-6" id="firstContainerPic">
            <img src="/pics/plane.jpg" alt="Image" class="img-fluid rounded">
        </div>
    </div>
</div>

<!-- Search Flight -->
<div class="container-fluid my-5" id="searchFlightContainer">
    <div class="row">
        <div class="col-md-12">
            <h2 class="text-center mb-4">Search Flights</h2>
            <form class="container" id="grpSearchContainer">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3 col-sm-6">
                        <label for="origin">Origin</label>
                        <input type="text" class="form-control" id="origin" placeholder="Manila">
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <label for="destination">Destination</label>
                        <input type="text" class="form-control" id="destination" placeholder="Cebu">
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <label for="departure">Departure Date</label>
                        <input type="date" class="form-control" id="departure">
                    </div>

                    <div class="col-md-3 col-sm-6">
                        <label for="arrival">Arrival Date</label>
                        <input type="date" class="form-control" id="arrival">
                    </div>
                    
                    <div class="col-12 text-center mt-3">
                        <a href="/search" class="btn btn-primary btn-lg">Search</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

