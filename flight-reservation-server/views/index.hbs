<!-- Promotion Carousel -->
<div class="container-fluid my-5" id="promoCarousel">
    <h2 class="text-center mb-4">Exclusive Promotions</h2>
    
    <div id="promoCarouselIndicators" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#promoCarouselIndicators" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#promoCarouselIndicators" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#promoCarouselIndicators" data-bs-slide-to="2"></button>
        </div>
        
        <div class="carousel-inner rounded-4">
            <div class="carousel-item active">
                <div class="promo-slide" style="background: linear-gradient(135deg, #5686c9, #3b6ea8);">
                    <div class="promo-content">
                        <div class="promo-badge">FLASH SALE</div>
                        <h2 class="promo-title">Up to 50% Off</h2>
                        <p class="promo-desc">Book now and get exclusive discounts on all domestic flights</p>
                        <div class="promo-code">
                            <span>Use Code: </span>
                            <strong>FLY50</strong>
                        </div>
                        <a href="#" class="btn btn-light btn-lg">Book Now</a>
                    </div>
                    <div class="promo-image">
                        <i class="fas fa-plane-departure"></i>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="promo-slide" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                    <div class="promo-content">
                        <div class="promo-badge">LIMITED OFFER</div>
                        <h2 class="promo-title">Summer Getaway</h2>
                        <p class="promo-desc">Enjoy special rates on international flights this summer</p>
                        <div class="promo-code">
                            <span>Use Code: </span>
                            <strong>SUMMER25</strong>
                        </div>
                        <a href="#" class="btn btn-light btn-lg">Explore Deals</a>
                    </div>
                    <div class="promo-image">
                        <i class="fas fa-sun"></i>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="promo-slide" style="background: linear-gradient(135deg, #10b981, #059669);">
                    <div class="promo-content">
                        <div class="promo-badge">GROUP DEAL</div>
                        <h2 class="promo-title">Family & Group Discount</h2>
                        <p class="promo-desc">Bring your loved ones and save up to 30% on group bookings</p>
                        <div class="promo-code">
                            <span>Use Code: </span>
                            <strong>GROUP30</strong>
                        </div>
                        <a href="#" class="btn btn-light btn-lg">View Offer</a>
                    </div>
                    <div class="promo-image">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <button class="carousel-control-prev" type="button" data-bs-target="#promoCarouselIndicators" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#promoCarouselIndicators" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>

<!-- Booking Steps -->
<div class="container-fluid my-5" id="bookSteps">
    <h2 class="text-center mb-4">How It Works</h2>

    <div class="row justify-content-center align-items-start g-4">
        <div class="col-md-2 col-sm-6 text-center">
            <div class="step-item">
                <div class="step-square">
                    <i class="fas fa-search"></i>
                </div>
                <h5 class="step-title mt-3">Search Flights</h5>
            </div>
        </div>
        
        <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center step-arrow-wrapper">
            <i class="fas fa-arrow-right step-arrow"></i>
        </div>
        
        <div class="col-md-2 col-sm-6 text-center">
            <div class="step-item">
                <div class="step-square">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h5 class="step-title mt-3">Choose Flight</h5>
            </div>
        </div>
        
        <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center step-arrow-wrapper">
            <i class="fas fa-arrow-right step-arrow"></i>
        </div>
        
        <div class="col-md-2 col-sm-6 text-center">
            <div class="step-item">
                <div class="step-square">
                    <i class="fas fa-user"></i>
                </div>
                <h5 class="step-title mt-3">Enter Details</h5>
            </div>
        </div>
        
        <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center step-arrow-wrapper">
            <i class="fas fa-arrow-right step-arrow"></i>
        </div>
        
        <div class="col-md-2 col-sm-6 text-center">
            <div class="step-item">
                <div class="step-square">
                    <i class="fas fa-credit-card"></i>
                </div>
                <h5 class="step-title mt-3">Confirm & Pay</h5>
            </div>
        </div>
    </div>
</div>

