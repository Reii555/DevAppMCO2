    <h1>Reservations</h1>

    <!--Reservations Table-->
    <div class="reservations-table-container">
        <div class="table-header">
            <div class="row g-3 mb-3">
                <!--Search-->
                <div class="col-md-3">
                    <input type="text" class="form-control" id="searchReservations" placeholder="Search Reservations...">
                </div>

                <!--filter-->
                <div class="col-md-3">
                    <select class="form-select" id="filterReservations">
                        <option value="all">All Reservations</option>
                        <option value="Confirmed">Confirmed Reservations</option>
                        <option value="Cancelled">Cancelled Reservations</option>
                    </select>
                </div>

                 <!--Sort by dropdown-->
                <div class="col-md-3">
                    <select class="form-select" id="sortReservations">
                        <option value="book_ref">Sort by Booking Reference</option>
                        <option value="pass_name">Sort by Passenger Name</option>
                        <option value="flight_route">Sort by Flight Route</option>
                        <option value="seat_no">Sort by Seat Number</option>
                        <option value="status">Sort by Status</option>
                        <option value="total_price">Sort by Total Price</option>
                    </select>
                </div>

                <!--Action Buttons-->
                <div class="col-md-3">
                    <button class="btn btn-warning w-100" id="editReservationBtn">
                        <i class="bi bi-pencil-fill"></i> Edit
                    </button>
                </div>
            </div>
        </div>

        <div class="reservations-table">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Booking Reference</th>
                        <th>Passenger Name</th>
                        <th>Flight Route</th>
                        <th>Seat Number</th>
                        <th>Status</th>
                        <th>Total Price</th>
                    </tr>
                </thead>
                <tbody id="reservationsTableBody">
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4"></td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3">
            
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item">
                            <button class="page-link" id="previousPage">Previous</button>
                        </li>

                        <li class="page-item">
                            <span class="page-link" id="currentPage">1</span>
                        </li>

                        <li class="page-item">
                            <button class="page-link" id="nextPage">Next</button>
                        </li>
                    </ul>
                </nav>
        </div>
    </div>

<!-- Custom JS -->
        <script src="admin-reservations.js"></script>