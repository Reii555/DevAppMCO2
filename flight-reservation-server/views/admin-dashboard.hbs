                            </table>
                        </div>
                    </div>

                    <!--Flight Activity Table-->
                    <div class="content-panel mt-4">
                        <div class="panel-header">Recent Flight Activity</div>

                        <div class="panel-body">
                            <ul class="list-group">
                                <li class="list-group-item">
                                    Flight PR123 was added.
                                </li>

                                <li class="list-group-item">
                                    Flight BR276 delayed.
                                </li>

                                <li class="list-group-item">
                                    Flight Br789 cancelled.
                                </li>
