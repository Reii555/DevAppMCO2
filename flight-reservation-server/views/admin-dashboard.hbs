                    <div class="content-panel mt-5">
                        <div class="panel-header">Recent Bookings</div>
                        <div class="panel-body">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Booking ID</th>
                                        <th>Passenger</th>
                                        <th>Route</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>BK001</td>
                                        <td>Linda Walker</td>
                                        <td>MNL -> JFK</td>
