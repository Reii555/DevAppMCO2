    <!--Main Content-->
    <div class="Admin-panel-main" id="adminMain">
        <h2 class="page-heading">Flight Management</h2>

        <!--Stats Board-->
        <div class="row g-3 mb-4">

            <div class="col-md-3">
                <div class="stat-card">
                    <h5>Total Flights</h5>
                    <h2 id="totalFlights">0</h2>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card">
                    <h5>Ongoing</h5>
                    <h2 id="ongoingFlights">0</h2>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card">
                    <h5>Delayed</h5>
                    <h2 id="delayedFlights">0</h2>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stat-card">
                    <h5>Cancelled</h5>
                    <h2 id="cancelledFlights">0</h2>
                </div>
            </div>

            <!--Controls-->
            <div class="flight-controls">

                <div class="row g-3">

                    <div class="col-md-4">
                        <input type="text" class="form-control" id="searchFlight"
                            placeholder="Search Flight ID or Airline">
                    </div>

                    <div class="col-md-2">
                        <select class="filter-dropdown" id="airlineFilter">
                            <option value="ALL">All Airlines</option>
                            {{#each airlines}}
                            <option value="{{this}}">{{this}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select class="filter-dropdown" id="statusFilter">
                            <option value="ALL">All Status</option>
                            <option value="Completed">Completed</option>
                            <option value="Delayed">Delayed</option>
                            <option value="Cancelled">Cancelled</option>
                            <option value="Upcoming">Upcoming</option>
                            <option value="Ongoing">Ongoing</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select class="sort-dropdown" id="sortFlight">
                            <option value="flight_number">Sort by Flight ID</option>
                            <option value="airline">Sort by Airline</option>
                            <option value="status">Sort by Status</option>
                        </select>
                    </div>

                    <!--CRUD Buttons-->
                    <div class="crud-toolbar mb-3">
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#flightModal" id="addBtn">
                            Add Flight
                        </button>

                        <button class="btn btn-warning" id="editBtn" disabled>
                            <i class="bi bi-pencil-fill"></i>
                            Edit
                        </button>

                        <button class="btn btn-danger" id="deleteBtn" disabled>
                            <i class="bi bi-trash-fill"></i>
                            Delete
                        </button>

                        <span class="ms-3 text-muted" id="selectedFlightLabel">
                            No flight selected
                        </span>
                    </div>

                    <!--Table-->
                    <div class="table-container">
                        <table class="table table-hover table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Flight ID</th>
                                    <th>Airline</th>
                                    <th>Cabin Class</th>
                                    <th>Route</th>
                                    <th>Departure</th>
                                    <th>Arrival</th>
                                    <th>Duration</th>
                                    <th>Trip Type</th>
                                    <th>Seats</th>
                                    <th>Base Price</th>
                                    <th>Checked-In</th>
                                    <th>Carry-On</th>
                                    <th>Layover Count</th>
                                    <th>Layover Details</th>
                                    <th>Status</th>
                                </tr>
                            </thead>

                            <tbody id="flightsTableBody">
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">

                        <span id="paginationInfo">Showing 1 of 5 to 10 flights </span>

                        <nav>
                            <ul class="pagination mb-0">
                                <li class="page-item">
                                    <button class="page-link" id="previousPage">Previous</button>
                                </li>

                                <li class="page-item">
                                    <span class="page-link" id="currentPage">1</span>
                                </li>

                                <li class="page-item">
                                    <button class="page-link" id="nextPage">Next</button>
                                </li>
                            </ul>
                        </nav>
                    </div>

                    <!--ADD/EDIT Flight Modals-->

                    <div class="modal fade" id="flightModal" tabindex="-1">

                        <div class="modal-dialog">

                            <div class="modal-content">
                                <div class="modal-header">

                                    <h5 class="modal-title" id="modalTitle">Add Flight</h5>

                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label" for="flight_number">Flight ID</label>
                                        <input type="text" class="form-control" id="flight_number" required>
                                        <div class="text-danger small" id="flightNumberError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Prefered Airlrine</label>
                                        <select class="form-select" id="airline" name="airline" required>
                                            <option value="">Any Airline</option>
                                            <option value="Philippine Airlines">Philippine Airlines</option>
                                            <option value="Cebu Pacific">Cebu Pacific</option>
                                            <option value="AirAsia">AirAsia</option>
                                            <option value="Sunlight Air">Sunlight Air</option>
                                            <option value="Royal Air Philippines">Royal Air Philippines</option>
                                        </select>
                                        <div class="text-danger small" id="airlineError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="cabinClass">Cabin Class</label>
                                        <select class="form-select" id="cabinClass" required>
                                            <option value="">Select Cabin Class</option>
                                            <option value="Economy">Economy</option>
                                            <option value="Premium Economy">Premium Economy</option>
                                            <option value="Business">Business</option>
                                            <option value="First Class">First Class</option>
                                        </select>

                                        <div class="text-danger small" id="cabinClassError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Origin Airport</label>
                                        <select class="form-select" id="origin" name="origin">
                                            <option value="">Select Origin</option>
                                            <option value="Manila (MNL)">Manila (MNL)</option>
                                            <option value="Cebu (CEB)">Cebu (CEB)</option>
                                            <option value="Clark (CRK)">Clark (CRK)</option>
                                            <option value="Davao (DVO)">Davao (DVO)</option>
                                            <option value="Iloilo (ILO)">Iloilo (ILO)</option>
                                            <option value="Bacolod (BCD)">Bacolod (BCD)</option>
                                            <option value="Puerto Princesa (PPS)">Puerto Princesa (PPS)</option>
                                            <option value="Siargao (IAO)">Siargao (IAO)</option>
                                            <option value="Bohol (TAG)">Bohol (TAG)</option>
                                            <option value="Zamboanga (ZAM)">Zamboanga (ZAM)</option>
                                        </select>
                                        <div class="text-danger small" id="originError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Destination Airport</label>
                                        <select class="form-select" id="destination" name="destination">
                                            <option value="">Select Destination</option>
                                            <option value="Manila (MNL)">Manila (MNL)</option>
                                            <option value="Cebu (CEB)">Cebu (CEB)</option>
                                            <option value="Clark (CRK)">Clark (CRK)</option>
                                            <option value="Davao (DVO)">Davao (DVO)</option>
                                            <option value="Iloilo (ILO)">Iloilo (ILO)</option>
                                            <option value="Bacolod (BCD)">Bacolod (BCD)</option>
                                            <option value="Puerto Princesa (PPS)">Puerto Princesa (PPS)</option>
                                            <option value="Siargao (IAO)">Siargao (IAO)</option>
                                            <option value="Bohol (TAG)">Bohol (TAG)</option>
                                            <option value="Zamboanga (ZAM)">Zamboanga (ZAM)</option>
                                        </select>
                                        <div class="text-danger small" id="destinationError"></div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label" for="departureTime">Departure Date & Time</label>
                                                <input type="datetime-local" class="form-control" id="departureTime" required>
                                                <div class="text-danger small" id="departureTimeError"></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label" for="arrivalTime">Arrival Date & Time</label>
                                                <input type="datetime-local" class="form-control" id="arrivalTime" required>
                                                <div class="text-danger small" id="arrivalTimeError"></div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label class="form-label" for="duration">Duration</label>
                                        <input
                                            type="text"
                                            class="form-control"
                                            id="duration"
                                            placeholder="e.g. 1h 30m"
                                            required>
                                        <div class="text-danger small" id="durationError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="tripType">Trip Type</label>
                                        <select class="form-select" id="tripType" required>
                                            <option value="">Select Trip Type</option>
                                            <option value="One-way">One-way</option>
                                            <option value="Round-trip">Round-trip</option>
                                        </select>
                                        <div class="text-danger small" id="tripTypeError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="availableSeats">Available Seats</label>
                                        <input type="number" class="form-control" id="availableSeats" required>
                                        <div class="text-danger small" id="availableSeatsError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="basePrice">Base Price</label>
                                        <input type="number" class="form-control" id="basePrice" min="0" step="0.01" placeholder="123.00" required>
                                        <div class="text-danger small" id="basePriceError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="checkedIn">Checked-in Baggage Allowance (kg)</label>
                                        <input type="number" class="form-control" id="checkedIn" min="0" required>
                                        <div class="text-danger small" id="checkedInError"></div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label class="form-label" for="carryOn">Carry-on Baggage Allowance (kg)</label>
                                        <input type="number" class="form-control" id="carryOn" min="0" required>
                                        <div class="text-danger small" id="carryOnError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="layoversCount">Layover Count</label>
                                        <input type="number" class="form-control" id="layoversCount" min="0" step="1" required>
                                        <div class="text-danger small" id="layoversCountError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="layoverDetails">Layover Details</label>
                                        <input type="text" class="form-control" id="layoverDetails">
                                        <div class="text-danger small" id="layoverDetailsError"></div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" for="status">Status</label>
                                        <select class="form-select" id="status" required>
                                            <option value="">Select Status</option>
                                            <option value="Completed">Completed</option>
                                            <option value="Delayed">Delayed</option>
                                            <option value="Cancelled">Cancelled</option>
                                            <option value="Upcoming">Upcoming</option>
                                            <option value="Ongoing">Ongoing</option>
                                        </select>
                                        <div class="text-danger small" id="statusError"></div>
                                    </div>
                                </div>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-primary" id="saveFlight">Save Flight</button>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!--DELETE Modal-->

                    <div class="modal fade" id="deleteModal" tabindex="-1">

                        <div class="modal-dialog modal-sm">
                            <div class="modal-content">
                                
                                <div class="modal-header">
                                    <h5 class="modal-title">Delete Flight?</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    Are you sure you want to delete the selected flight?
                                    <p style="color:tomato"><strong>This action cannot be undone.</strong></p>
                                </div>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    </div>
    </div>

    <!--Custom JS-->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="/js/admin-flights.js"></script>
</body>

</html>