  <h1>Users</h1>

    <!--Users Table-->
    <div class="users-table-container">
        <div class="table-header">
            <div class="row g-3 mb-3">
                <!--Search-->
                <div class="col-md-4">
                    <input type="text" class="form-control" id="searchUsers" placeholder="Search Users...">
                </div>

                <!--filter-->
                <div class="col-md-4">
                    <select class="form-select" id="filterUsers">
                        <option value="all">All Users</option>
                        <option value="active">Active Users</option>
                        <option value="deleted">Deleted Users</option>
                    </select>
                </div>

                 <!--Sort by dropdown-->
                <div class="col-md-4">
                    <select class="form-select" id="sortUsers">
                        <option value="id">Sort by ID</option>
                        <option value="name">Sort by Name</option>
                        <option value="email">Sort by Email</option>
                        <option value="created_at">Sort by Created At</option>
                        <option value="last_login">Sort by Last Login</option>
                        <option value="status">Sort by Status</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="users-table">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Created At</th>
                        <th>Last Login</th>
                        <th>Status</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    {{#each users}}
                    <tr data-id="{{this.id}}" data-status="{{this.status}}">
                        <td>{{this.id}}</td>
                        <td>{{this.name}}</td>
                        <td>{{this.email}}</td>
                        <td>{{this.phone}}</td>
                        <td>{{formatDate this.created_at}}</td>
                        <td>{{formatDate this.last_login}}</td>
                        <td><span class="badge {{#if (eq this.status 'active')}}bg-success{{else}}bg-danger{{/if}}">{{this.status}}</span></td>
                        <td>{{this.role}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3">

            <span id="paginationInfo">Showing 1 of 2 to 8 Users </span>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item">
                            <button class="page-link" id="previousPage">Previous</button>
                        </li>

                        <li class="page-item">
                            <span class="page-link" id="currentPage">1</span>
                        </li>

                        <li class="page-item">
                            <button class="page-link" id="nextPage">Next</button>
                        </li>
                    </ul>
                </nav>
        </div>
    </div>

    <!-- Custom JS -->
        <script src="/js/admin-users.js"></script>