<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnimoSkies Admin - {{title}}</title>

    <!--jQuery-->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!--Bootstrap-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!--CSS-->
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <link rel="stylesheet" href="/css/admin-flights.css">
    <link rel="stylesheet" href="/css/admin-reservations-designs.css">
    <link rel="stylesheet" href="/css/admin-users-design.css">
</head>

<body>

<!--Top Bar-->
    <div class="top-bar">
        <div class="top-bar-left">
            <button class="toggle-sidebar-btn" id="sidebarButtones">
                <i class="fas fa-bars"></i>
            </button>

            <div class="admin-user-dropdown">
                <button class="btn admin-user-btn dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle"></i>
                        {{user.email}}
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="/logout">Logout</a></li>
                </ul>
            </div>
        </div>

        <div class="top-bar-right">
            <h3>Admin Panel - {{title}}</h3>
            <i class="fas fa-plane-departure me-2"></i>
        </div>
    </div>

<!--SIDEBAR-->

<div class="sidebar" id="sidebar">
    <nav class="sidebar-nav">

        <!--Dashboard Section-->
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link-Dashboard" href="/admin-dashboard">Dashboard</a>
            </li>
        </ul>

        <!--Manage Section-->
        <div class="nav-section-title">Manage</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link-Flights" href="/admin-flights">Flights</a>
            </li>

            <li class="nav-item">
                <a class="nav-link-Users" href="/admin-users">Users</a>
            </li>

            <li class="nav-item">
                <a class="nav-link-Reservations" href="/admin-reservations">Reservations</a>
            </li>
        </ul>
    </nav>
</div>

<!-- Main -->
<div class="admin-main-content" id="adminMainContent">
    <div style="padding-top: 25px;">
    {{{body}}}
</div>
    
    <!--Bootstrap 5 Bundle-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    //sidebar toggle
    $('#sidebarButtones').click(function(e) {
        e.stopPropagation();
        
        // Toggles the 'hidden' class on sidebar
        $('#sidebar').toggleClass('hidden');
        
        // Toggles the 'sidebar-open' class on main content
        $('#adminMainContent').toggleClass('sidebar-open');
        
    });
    </script>
</body>
</html>