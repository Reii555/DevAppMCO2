<!DOCTYPE>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Login | Animo Skies</title>

        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/login-design.css">

        <!-- jQuery -->
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    </head>

    <body>
        <div class="login-container">
            <div class="login-card">
                <!-- left side of the card 
                    Login
                    (mini, thin opaque line here)
                    "Username"
                    (line where users can type their username)
                    "Password"
                    (line where users can type their username)

                    button to sign in
                -->
                <div class="login-left">
                    <div class="login-content">

                        <!-- Display error or success messages -->
                    {{#if error}}
                        <div class="alert alert-danger">{{error}}</div>
                    {{/if}}
                    {{#if success}}
                        <div class="alert alert-success">{{success}}</div>
                    {{/if}}

                        <form action="/login" method="POST" class="login-form">
                            <h2 class="login-title">Login</h2>

                            <div class="login-divider"></div>

                            <div class="form-group">
                                <input type="email" id="email" name="email" class="form-control" value="{{formData.email}}" required autofocus>
                            </div>

                            <div class="pass-wrapper">
                                <input type="password" id="password" name="password" class="form-control" required>

                                <!-- Password Toggle Button -->
                                <button type="button" class="toggle-password" id="togglePassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>

                            <button type="submit" class="btn-login">
                                Sign In
                            </button>
                        </form>

                        <p class="register-link">
                            <a href="/register">Don't have an account? Register here.</a>
                        </p>
                    </div>
                </div>

                <!-- right side of the card 
                    "Animo
                    Skies" 
                    "Connecting Journeys,
                    Creating Memories"
                -->
                <div class="login-right">
                    <div class="brand-content">
                     <h1 class="brand-title">Animo Skies</h1>
                    
                    <!-- Tagline -->
                    <p class="catchy-line">Connecting Journeys,</p>
                    <p class="catchy-line">Creating Memories</p>
                </div>
            </div>

        </div>
    </div>

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="/js/login-script.js"></script>
    </body>
</html>